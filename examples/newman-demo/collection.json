{
  "info": {
    "name": "Acme API",
    "_postman_id": "0c0c0c0c-0000-0000-0000-000000000001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "@critical/Auth",
      "item": [
        {
          "name": "POST /login (valid creds)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "https://httpbin.org/anything/login", "protocol": "https", "host": ["httpbin","org"], "path": ["anything","login"] },
            "body": { "mode": "raw", "raw": "{\"email\":\"alice@example.com\",\"password\":\"hunter2\"}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('returns json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('json'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "GET /products",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "https://httpbin.org/anything/products", "protocol": "https", "host": ["httpbin","org"], "path": ["anything","products"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.expect(pm.response.code).to.equal(200));",
                  "pm.test('body contains products array', () => pm.expect(pm.response.text()).to.include('products'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /products/missing @minor",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "https://httpbin.org/status/404", "protocol": "https", "host": ["httpbin","org"], "path": ["status","404"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 404', () => pm.expect(pm.response.code).to.equal(404));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
