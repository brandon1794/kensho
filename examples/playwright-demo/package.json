{
  "name": "playwright-demo",
  "version": "0.0.0",
  "private": true,
  "description": "Example Playwright project wired to the Kensho reporter.",
  "type": "module",
  "scripts": {
    "seed": "node scripts/seed-results.mjs",
    "generate": "node ../../packages/cli/bin/kensho.js generate --input ./kensho-results --output ./kensho-report",
    "open": "node ../../packages/cli/bin/kensho.js open --report ./kensho-report",
    "validate": "node ../../packages/cli/bin/kensho.js validate ./kensho-results",
    "demo": "pnpm run seed && pnpm run generate && pnpm run open"
  },
  "dependencies": {
    "@kaizenreport/kensho-playwright": "workspace:*",
    "@kaizenreport/kensho-schema": "workspace:*"
  }
}
