<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>10.0</LangVersion>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <PackageId>KaizenReport.Kensho.Xunit</PackageId>
    <Version>0.1.0</Version>
    <Authors>KaizenReport</Authors>
    <Company>KaizenReport</Company>
    <Description>xUnit hook that emits the Kensho v1 JSON test-report format. Apply [KenshoTracked] at the assembly level (or extend KenshoTestBase) and the run.json + cases/*.json appear under kensho-results/ when the test run finishes.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/kaizenreport/kensho</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kaizenreport/kensho</RepositoryUrl>
    <PackageTags>kensho;kaizenreport;xunit;testing;test-report;reporter</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.extensibility.execution" Version="2.6.1" />
    <PackageReference Include="xunit.extensibility.core" Version="2.6.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\dotnet-core\KaizenReport.Kensho.Core.csproj" />
  </ItemGroup>

</Project>
